---
import Layout from '../layouts/Layout.astro';
const FORM = "/start";
const CONTACT = "mailto:hello@revagentic.ai";

const wasteItems = [
  { title: "Automations that aren't firing", body: "Set up once, broken since. Nobody noticed because nobody checked." },
  { title: "Sequences never turned on", body: "Built during onboarding, sitting in draft. Revenue sitting with them." },
  { title: "Integrations with zero usage", body: "Paying monthly fees for connections your team forgot existed." },
  { title: "Manual workflows that should be automatic", body: "Staff time going to follow-up and outreach that a system should run." }
];

const auditItems = [
  { icon: "📋", title: "Stack inventory", body: "Every tool, every integration, every fee — mapped and categorized" },
  { icon: "📊", title: "Usage analysis", body: "What's actually being used vs. what you're paying for" },
  { icon: "⚡", title: "Automation audit", body: "Which automations are live, broken, or never turned on" },
  { icon: "💰", title: "Cost vs. value", body: "Clear picture of what to keep, cut, and rebuild" }
];

const steps = [
  { step: "01", title: "Revenue Systems Diagnostic", body: "We audit your current stack and revenue lifecycle. Clear picture of what to keep, what to cut, and what to rebuild — before any work begins." },
  { step: "02", title: "System Design", body: "We design the CRM architecture around your operation: member journey stages, automation triggers, staff touchpoints, reporting views." },
  { step: "03", title: "Build on Airtable + Claude", body: "Airtable as the database and workflow engine. Claude as the intelligence layer — drafting messages, flagging risks, generating reports. Built for you, not from a template." },
  { step: "04", title: "Onboarding Automation", body: "New members enter a structured first-30-days sequence. Day 1 welcome. Week 1 check-in. Class feedback. Goal nudge. All automatic. All personal." },
  { step: "05", title: "Retention Signals", body: "The CRM tracks engagement — visit frequency, class attendance, response rates. When a member goes quiet, it flags them before they cancel and triggers re-engagement." },
  { step: "06", title: "Handoff to Revenue Recovery", body: "When a member lapses or a payment fails, the CRM passes them to Revenue Recovery automatically. Nothing falls through the cracks." }
];

const deliverables = [
  "Full audit of your current CRM/stack with waste analysis and cost breakdown",
  "Custom-built Airtable base (member database, pipeline, reporting views)",
  "Claude-powered automation and messaging layer",
  "New member onboarding sequence (30-day automated touchpoints)",
  "At-risk member detection and re-engagement trigger logic",
  "Staff-facing dashboard (member status, action queue)",
  "Integration with Agentic SDR (inbound) and Revenue Recovery (lapsed)",
  "Monthly retention metrics reporting"
];

const lifecycleLinks = [
  { href: "/agentic-sdr", label: "Agentic SDR", desc: "Feeds qualified, booked leads into the CRM", stage: "Stage 01" },
  { href: "/revenue-recovery", label: "Revenue Recovery", desc: "Receives lapsed and failed-payment signals automatically", stage: "Stage 03" }
];
---

<Layout
  title="Custom CRM | RevAgentic"
  description="HubSpot was supposed to do this. It didn't. RevAgentic audits your current CRM, cuts the bloat, and rebuilds a purpose-built revenue system on Airtable and Claude."
>

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-brand-border bg-white/95 backdrop-blur-sm">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="font-display font-bold text-base text-brand-navy tracking-tight">revagentic<span class="text-brand-purple">.ai</span></a>
      <div class="hidden md:flex items-center gap-8 text-sm text-brand-muted font-body">
        <a href="/how-it-works" class="hover:text-brand-navy transition-colors">How It Works</a>
        <a href="/agentic-sdr" class="hover:text-brand-navy transition-colors">Agentic SDR</a>
        <a href="/custom-crm" class="text-brand-navy font-medium transition-colors">Custom CRM</a>
        <a href="/revenue-recovery" class="hover:text-brand-navy transition-colors">Revenue Recovery</a>
      </div>
      <a href={FORM} target="_blank" class="bg-brand-purple text-white font-display font-semibold text-sm px-5 py-2.5 rounded-lg hover:brightness-110 transition-all">
        Book a Diagnostic
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="min-h-screen flex flex-col justify-center pt-16 px-6">
    <div class="max-w-6xl mx-auto w-full py-24 grid md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-brand-purple font-body font-semibold text-xs uppercase tracking-widest mb-4">Stage 02 — Convert & Retain</p>
        <h1 class="font-display font-extrabold text-5xl md:text-6xl leading-[1.05] tracking-tight mb-6 text-brand-navy">
          HubSpot was supposed to do this. It didn't.
        </h1>
        <p class="text-brand-muted text-lg font-body leading-relaxed mb-10">
          You've been paying for a platform you half-use, with automations that still require someone to manage them. We audit what you have, cut what isn't working, and rebuild it as a system that runs.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={FORM} target="_blank" class="inline-flex items-center justify-center gap-2 bg-brand-purple text-white font-display font-semibold text-base px-8 py-4 rounded-lg hover:brightness-110 transition-all">
            Start with a Revenue Systems Diagnostic
          </a>
          <a href={CONTACT} class="inline-flex items-center justify-center gap-2 border border-brand-border bg-white text-brand-navy font-display font-semibold text-base px-8 py-4 rounded-lg hover:border-brand-purple hover:text-brand-purple transition-all">
            Contact RevAgentic
          </a>
        </div>
      </div>

      <div class="hidden md:flex items-center justify-center">
        <div class="grid grid-cols-2 gap-4 w-full max-w-md">
          {[
            { title: "Audit First", copy: "See the waste before we touch anything" },
            { title: "Airtable + Claude", copy: "Purpose-built, not repurposed" },
            { title: "Member Onboarding", copy: "30-day automated sequences" },
            { title: "Retention Signals", copy: "Flag at-risk members automatically" }
          ].map((item, index) => (
            <div class={`border border-brand-border rounded-xl p-6 ${index % 2 === 0 ? 'bg-white' : 'bg-brand-bg'}`}>
              <p class="text-brand-muted font-body text-xs uppercase tracking-widest mb-3">{item.title}</p>
              <p class="font-display font-bold text-brand-navy text-lg leading-tight">{item.copy}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- PAIN -->
  <section class="px-6 py-24 border-t border-brand-border bg-white">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display font-bold text-4xl mb-4 text-brand-navy">You're not paying for a CRM. You're paying for a contact database with expensive features collecting dust.</h2>
      <p class="text-brand-muted font-body text-lg leading-relaxed max-w-3xl mb-12">
        Most fitness operators use HubSpot — or Mindbody, or Salesforce — for about 15% of what it offers. The rest is shelfware. And meanwhile, new members aren't getting onboarded properly, at-risk members are churning without a single flag, and staff is manually doing what should be automatic. You're paying $400–$1,200/month for the privilege.
      </p>

      <div class="grid md:grid-cols-4 gap-4">
        {wasteItems.map((item) => (
          <div class="bg-brand-bg border border-brand-border rounded-xl p-6">
            <h3 class="font-display font-semibold text-brand-navy mb-2 leading-snug">{item.title}</h3>
            <p class="text-brand-muted font-body text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HUBSPOT TEARDOWN -->
  <section class="px-6 py-24 border-t border-brand-border bg-brand-bg">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand-purple font-body font-semibold text-xs uppercase tracking-widest mb-4">The Audit-First Approach</p>
      <h2 class="font-display font-bold text-4xl mb-4 text-brand-navy">We show you the waste before we touch anything.</h2>
      <p class="text-brand-muted font-body leading-relaxed max-w-3xl mb-12">
        Every Custom CRM engagement starts with a teardown. We map your current system — what you're paying for, what you're using, what's actually running, and what's sitting idle. You'll see exactly what's costing you vs. what's delivering value before we rebuild anything.
      </p>

      <div class="grid md:grid-cols-4 gap-4">
        {auditItems.map((item) => (
          <div class="bg-white border border-brand-border rounded-xl p-6">
            <p class="text-2xl mb-4">{item.icon}</p>
            <h3 class="font-display font-semibold text-brand-navy mb-2">{item.title}</h3>
            <p class="text-brand-muted font-body text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works" class="px-6 py-24 border-t border-brand-border bg-brand-navy text-white">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display font-bold text-4xl mb-4 text-white">How the Custom CRM works</h2>
      <p class="text-gray-400 font-body leading-relaxed max-w-3xl mb-12">
        The connective tissue of the entire revenue system — from audit to a running operation that doesn't require babysitting.
      </p>

      <div class="grid md:grid-cols-3 gap-8">
        {steps.map((item) => (
          <div>
            <p class="font-display font-black text-4xl text-brand-cyan/40 mb-4">{item.step}</p>
            <h3 class="font-display font-bold text-white mb-3">{item.title}</h3>
            <p class="text-gray-400 font-body text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT YOU GET -->
  <section id="what-you-get" class="px-6 py-24 border-t border-brand-border bg-white">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display font-bold text-4xl mb-4 text-brand-navy">What you actually get</h2>
      <p class="text-brand-muted font-body leading-relaxed max-w-3xl mb-12">
        Not a HubSpot replacement for its own sake. A purpose-built system that does what your current CRM promised — at a fraction of the cost, with none of the bloat.
      </p>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-brand-bg border border-brand-border rounded-xl p-8">
          <p class="text-brand-purple font-body font-semibold text-xs uppercase tracking-widest mb-6">Deliverables</p>
          <ul class="space-y-3">
            {deliverables.map((item) => (
              <li class="flex items-start gap-3 text-brand-muted font-body text-sm">
                <span class="text-brand-purple mt-0.5">→</span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-brand-navy border border-brand-navy rounded-xl p-8 text-white">
          <p class="text-brand-cyan font-body font-semibold text-xs uppercase tracking-widest mb-6">Why Airtable + Claude</p>
          <div class="space-y-4">
            {[
              { label: "No vendor lock-in", body: "You own the system. It runs on tools you control." },
              { label: "Built for your operation", body: "Not a generic template — designed around how your club actually runs." },
              { label: "Fraction of the cost", body: "Airtable + Claude costs a fraction of HubSpot at full capability." },
              { label: "Grows with you", body: "Add stages, automations, and integrations as the business grows." }
            ].map((item) => (
              <div class="bg-white/5 border border-white/10 rounded-lg px-5 py-4">
                <p class="font-display font-semibold text-white text-sm mb-1">{item.label}</p>
                <p class="text-gray-400 font-body text-sm">{item.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- LIFECYCLE -->
  <section class="px-6 py-24 border-t border-brand-border bg-brand-bg">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-start">
      <div>
        <p class="text-brand-purple font-body font-semibold text-xs uppercase tracking-widest mb-4">Lifecycle</p>
        <h2 class="font-display font-bold text-4xl mb-6 text-brand-navy">The CRM is the system everyone else plugs into.</h2>
        <p class="text-brand-muted font-body leading-relaxed mb-6">
          Without the Custom CRM, the Agentic SDR has nowhere to hand off to. Revenue Recovery has no signal to act on. Stage 2 is the infrastructure that makes everything else possible.
        </p>

        <div class="flex flex-wrap items-center gap-4 font-display font-bold text-brand-navy text-xl mb-8">
          <span class="text-brand-muted">Acquire</span>
          <span class="text-brand-purple">→</span>
          <span>Convert &amp; Retain</span>
          <span class="text-brand-purple">→</span>
          <span class="text-brand-muted">Recover</span>
        </div>

        <p class="text-brand-muted font-body text-sm leading-relaxed">
          The SDR fills the pipeline. The CRM converts it and retains members. Recovery catches what slips through. Each stage runs on the data from the one before it.
        </p>
      </div>

      <div class="bg-white border border-brand-border rounded-xl p-8">
        <p class="text-brand-muted text-sm font-body uppercase tracking-widest mb-6">Connected system layers</p>
        <div class="space-y-4">
          {lifecycleLinks.map((item) => (
            <a href={item.href} class="flex items-start justify-between bg-brand-bg border border-brand-border rounded-lg px-5 py-4 hover:border-brand-purple transition-all group">
              <div>
                <p class="text-brand-purple font-body text-xs uppercase tracking-widest mb-1 font-semibold">{item.stage}</p>
                <p class="font-display font-semibold text-brand-navy group-hover:text-brand-purple transition-colors">{item.label}</p>
                <p class="text-brand-muted font-body text-xs mt-1">{item.desc}</p>
              </div>
              <span class="text-brand-purple mt-1">→</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-6 py-24 border-t border-brand-border bg-brand-navy text-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-display font-black text-4xl md:text-5xl mb-6">
        Find out what your current CRM is actually costing you.
      </h2>
      <p class="text-gray-400 text-lg mb-10 leading-relaxed">
        The audit is the first step. It costs you nothing to know.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href={FORM} target="_blank" class="inline-flex items-center justify-center bg-brand-purple text-white font-display font-semibold text-lg px-10 py-5 rounded-lg hover:brightness-110 transition-all">
          Start with a Revenue Systems Diagnostic
        </a>
        <a href={CONTACT} class="inline-flex items-center justify-center border border-brand-cyan text-brand-cyan font-display font-semibold text-lg px-10 py-5 rounded-lg hover:bg-brand-cyan/10 transition-all">
          Contact RevAgentic
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-brand-border px-6 py-8 bg-white">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-brand-muted text-sm">
      <a href="/" class="font-display font-bold text-brand-navy">revagentic<span class="text-brand-purple">.ai</span></a>
      <p>© {new Date().getFullYear()} RevAgentic. All rights reserved.</p>
    </div>
  </footer>

</Layout>
